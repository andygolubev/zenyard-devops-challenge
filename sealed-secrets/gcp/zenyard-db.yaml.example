  name: zenyard-db
  namespace: zenyard
spec:
  encryptedData:
    DB_USER: AgB...<encrypted>...
    DB_PASSWORD: AgB...<encrypted>...
  template:
    metadata:
      name: zenyard-db
      namespace: zenyard
    type: Opaque
