# PLACEHOLDER — not applied. The real `zenyard-postgresql.yaml` is generated by
# `make gcp-seal-secrets` against the remote cluster and committed alongside this file.
# Consumed by: PostgreSQL subchart (postgresql.auth.existingSecret: zenyard-postgresql).
# Bitnami keys: postgres-password (superuser) and password (the zenyard user).
# `password` MUST equal DB_PASSWORD in zenyard-db so the app can connect.
apiVersion: bitnami.com/v1alpha1
kind: SealedSecret
metadata:
  name: zenyard-postgresql
  namespace: zenyard
spec:
  encryptedData:
    postgres-password: AgB...<encrypted>...
    password: AgB...<encrypted>...
  template:
    metadata:
      name: zenyard-postgresql
      namespace: zenyard
    type: Opaque
